{
    "id": "myip",
    "name": "My IP",
    "description": "Launcher plugin to view and copy your private, public, and Tailscale IPs (v4 and v6) along with your Tailscale MagicDNS hostname",
    "version": "1.0.0",
    "author": "dwright134",
    "icon": "language",
    "screenshot": "https://raw.githubusercontent.com/dwright134/dms-myip/main/docs/myip-launcher.png",
    "screenshots": ["https://raw.githubusercontent.com/dwright134/dms-myip/main/docs/myip-launcher.png"],
    "type": "launcher",
    "capabilities": ["launcher"],
    "component": "./MyIPLauncher.qml",
    "settings": "./MyIPSettings.qml",
    "trigger": "myip",
    "requires_dms": ">=1.4.0",
    "requires": ["curl"],
    "permissions": ["settings_read", "settings_write", "process"]
}
